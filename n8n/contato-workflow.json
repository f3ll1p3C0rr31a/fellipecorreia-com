        "gmailOAuth2": { "id": "Gm41LoAuthCredFC1", "name": "Gmail - Fellipe" }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true }",
        "options": {}
      },
      "id": "e4a44444-4444-4444-8444-444444444444",
      "name": "Responder OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [940, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Nao e bot", "type": "main", "index": 0 }]] },
    "Nao e bot": {
      "main": [
        [{ "node": "Enviar Gmail", "type": "main", "index": 0 }],
