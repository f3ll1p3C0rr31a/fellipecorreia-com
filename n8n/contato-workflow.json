          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c2a22222-2222-4222-8222-222222222222",
      "name": "Nao e bot",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "sendTo": "fellipebayeh@gmail.com",
