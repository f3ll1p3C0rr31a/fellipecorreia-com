        "message": "=Nome:  {{ $json.body.name }}\nEmail: {{ $json.body.email }}\n\n{{ $json.body.message }}\n\n-- enviado por {{ $json.body.source }}",
        "options": { "replyTo": "={{ $json.body.email }}" }
