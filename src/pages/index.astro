---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Homelab from '../components/Homelab.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import SectionBreak from '../components/SectionBreak.astro';
import BootSequence from '../components/fx/BootSequence.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { bootLines } from '../data/boot';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base>
  <BootSequence skipLabel={t('boot.skip')} gateLabel={t('boot.gate')} lines={bootLines[lang]} />
  <Nav />

  <main>
    <Hero />

    <SectionBreak variant="gradient" label="01_about" />
    <About />

    <SectionBreak variant="nfo" label="02_skills" />
    <Skills />

    <SectionBreak variant="circuit" label="03_projects" />
    <Projects />

    <SectionBreak variant="wave" label="04_homelab" />
    <Homelab />

    <SectionBreak variant="gradient" label="05_experience" />
    <Experience />

    <SectionBreak variant="nfo" label="06_contact" />
    <Contact />
  </main>

  <Footer />
</Base>
