---
import SectionHeader from './SectionHeader.astro';
import ContactForm from './fx/ContactForm.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import { site } from '../data/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cv = localizePath(lang, '/cv');

const channels = [
  { key: 'email', value: site.email, href: `mailto:${site.email}` },
  { key: 'whatsapp', value: t('contact.whatsapp.cta'), href: site.whatsapp.href, ext: true },
  { key: 'linkedin', value: '/in/f3llipecorreia', href: site.social.linkedin, ext: true },
  { key: 'github', value: '/f3ll1p3C0rr31a', href: site.social.github, ext: true },
];
---

<section id="contato" class="mx-auto max-w-6xl scroll-mt-16 px-4 py-16 sm:px-6">
  <SectionHeader index={6} id="contato" cmd="./contato.sh" title={lang === 'pt' ? 'contato' : 'contact'} accent="volt" />

  <p class="mb-8 max-w-2xl font-display text-lg font-semibold leading-snug text-bone sm:text-xl">
    {t('contact.lead')}
  </p>

  <div class="grid gap-6 lg:grid-cols-2">
    {/* formulário (n8n) */}
    <ContactForm />

    {/* canais + CVs */}
    <div class="flex flex-col gap-6">
      <div class="overflow-hidden border border-royal/60 bg-royal/10">
        <div class="flex items-center gap-1.5 border-b border-royal/60 bg-royal/20 px-3 py-2 font-mono text-xs">
          <span class="size-2 rounded-full bg-acid"></span>
          <span class="size-2 rounded-full bg-volt"></span>
          <span class="size-2 rounded-full bg-ash/40"></span>
          <span class="ml-2 text-ash">{t('form.or')}</span>
        </div>
        <ul class="divide-y divide-royal/30 p-2 font-mono text-xs sm:text-sm">
          {
            channels.map((c) => (
              <li>
                <a
                  href={c.href}
                  target={c.ext ? '_blank' : undefined}
                  rel={c.ext ? 'noopener' : undefined}
                  class="group flex items-center gap-3 px-2 py-2.5 transition-colors hover:bg-royal/20"
                >
                  <span class="text-volt">&gt;</span>
                  <span class="w-20 shrink-0 text-ash">{c.key}</span>
                  <span class="hidden text-royal sm:inline">......</span>
                  <span class="truncate text-bone transition-colors group-hover:text-acid">{c.value}</span>
                  <span class="ml-auto text-royal transition-colors group-hover:text-acid">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="flex flex-col gap-3">
        <p class="font-mono text-xs uppercase tracking-widest text-volt">// {t('contact.cv.title')}</p>
        <a
          href={cv}
          class="group flex items-center justify-between border border-acid/60 bg-acid/5 px-5 py-3 font-mono text-xs text-acid transition-colors hover:bg-acid hover:text-void"
        >
          <span><span class="opacity-60">./</span>{t('contact.cv.dev')}</span>
          <span>↓</span>
        </a>
      </div>
    </div>
  </div>
</section>
