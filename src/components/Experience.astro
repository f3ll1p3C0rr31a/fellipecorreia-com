---
import SectionHeader from './SectionHeader.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { jobs } from '../data/experience';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="experiencia" class="mx-auto max-w-6xl scroll-mt-16 px-4 py-16 sm:px-6">
  <SectionHeader
    index={5}
    id="experiencia"
    cmd="git log --career"
    title={lang === 'pt' ? 'experiência' : 'experience'}
    accent="acid"
  />

  <p class="mb-10 max-w-3xl border-l-2 border-acid pl-4 font-mono text-sm leading-relaxed text-ash sm:text-base">
    {t('exp.lead')}
  </p>

  <ol class="relative space-y-8 border-l border-royal/40 pl-6">
    {
      jobs.map((job) => (
        <li class="relative">
          {/* nó da timeline */}
          <span class="absolute -left-[27px] top-1.5 size-3 rounded-full border-2 border-acid bg-void" />

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h3 class="font-display text-lg font-bold uppercase tracking-tight text-bone">{job.company}</h3>
            {job.brands && <span class="font-mono text-[11px] text-royal">{job.brands}</span>}
            <span class="ml-auto font-mono text-xs text-ash">
              <span class:list={[job.current && 'text-toxic']}>{job.period[lang]}</span>
              <span class="text-royal">·</span> {job.location}
            </span>
          </div>
          <p class="mt-0.5 font-mono text-xs text-acid">{job.role[lang]}</p>

          <ul class="mt-3 space-y-1.5">
            {job.highlights[lang].map((h) => (
              <li class="flex gap-2 font-mono text-xs leading-relaxed text-ash sm:text-sm">
                <span class="text-royal">▹</span>
                {h}
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
