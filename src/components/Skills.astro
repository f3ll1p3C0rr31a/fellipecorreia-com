---
import SectionHeader from './SectionHeader.astro';
import { getLangFromUrl } from '../i18n/utils';
import { site } from '../data/site';
import { sysinfo, skills, paletteBlocks } from '../data/skills';
import skull from '../data/skull.txt?raw';

const lang = getLangFromUrl(Astro.url);
const info = sysinfo(lang);
---

<section id="skills" class="mx-auto max-w-6xl scroll-mt-16 px-4 py-16 sm:px-6">
  <SectionHeader index={2} id="skills" cmd="neofetch --skills" title="skills" accent="volt" />

  {/* janela de terminal */}
  <div class="overflow-hidden border border-royal/60 bg-royal/10">
    <div class="flex items-center gap-1.5 border-b border-royal/60 bg-royal/20 px-3 py-2 font-mono text-xs">
      <span class="size-2 rounded-full bg-acid"></span>
      <span class="size-2 rounded-full bg-volt"></span>
      <span class="size-2 rounded-full bg-ash/40"></span>
      <span class="ml-2 text-ash">{site.handle} — neofetch</span>
    </div>

    <div class="grid gap-6 p-5 sm:p-6 lg:grid-cols-[auto_1fr] lg:gap-10">
      {/* arte ASCII */}
      <pre
        class="hidden shrink-0 select-none self-center font-mono text-[10px] leading-tight text-volt drop-shadow-[0_0_8px_rgba(255,204,0,0.35)] sm:block sm:text-xs"
        aria-hidden="true">{skull}</pre>

      {/* info block */}
      <div class="min-w-0 font-mono text-xs sm:text-sm">
        <p class="text-bone">
          <span class="text-volt">{site.handle.split('@')[0]}</span>@<span class="text-volt"
            >{site.handle.split('@')[1]}</span
          >
        </p>
        <p class="mb-2 text-dim">-----------------------------</p>

        {/* sysinfo */}
        {
          info.map((row) => (
            <p class="flex flex-wrap gap-x-2 text-ash">
              <span class="w-16 shrink-0 font-semibold text-volt">{row.k}</span>
              <span class="text-bone">{row.v}</span>
            </p>
          ))
        }

        <p class="my-2 text-dim">-----------------------------</p>

        {/* skills */}
        {
          skills.map((cat) => (
            <p class="flex flex-wrap gap-x-2 text-ash">
              <span class="w-16 shrink-0 font-semibold text-volt">{cat.key}</span>
              <span class="text-bone">{cat.items.join(', ')}</span>
            </p>
          ))
        }

        {/* blocos de cor */}
        <div class="mt-4 flex gap-1" aria-hidden="true">
          {paletteBlocks.map((c) => <span class="h-4 w-6" style={`background:${c}`} />)}
        </div>
        <p class="mt-1 text-[10px] text-dim">* Rust: básico / em estudo</p>
      </div>
    </div>
  </div>
</section>
