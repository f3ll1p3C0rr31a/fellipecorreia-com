---
import SectionHeader from './SectionHeader.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { site } from '../data/site';
import { homelabStats, homelabServices } from '../data/homelab';
import diagram from '../data/homelab-diagram.txt?raw';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const stats = homelabStats(lang);
---

<section id="homelab" class="mx-auto max-w-6xl scroll-mt-16 px-4 py-16 sm:px-6">
  <SectionHeader index={4} id="homelab" cmd="docker ps | wc -l" title="homelab" accent="volt" />

  {/* lead provocativo */}
  <p class="mb-8 max-w-3xl border-l-2 border-volt pl-4 font-mono text-sm leading-relaxed text-bone sm:text-base">
    {t('homelab.lead')}
  </p>

  {/* stats */}
  <div class="mb-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
    {
      stats.map((s) => (
        <div class="border border-royal/50 bg-royal/10 p-4">
          <div class="font-display text-3xl font-extrabold text-volt sm:text-4xl">{s.n}</div>
          <div class="mt-1 font-mono text-[11px] leading-tight text-ash">{s.label}</div>
        </div>
      ))
    }
  </div>

  {/* diagrama de rede */}
  <div class="overflow-hidden border border-royal/60 bg-royal/10">
    <div class="flex items-center gap-1.5 border-b border-royal/60 bg-royal/20 px-3 py-2 font-mono text-xs">
      <span class="size-2 rounded-full bg-acid"></span>
      <span class="size-2 rounded-full bg-volt"></span>
      <span class="size-2 rounded-full bg-ash/40"></span>
      <span class="ml-2 text-ash">{site.handle}:~$ traceroute {t('homelab.diagram')}</span>
    </div>
    <div class="overflow-x-auto p-4 sm:p-6">
      <pre
        class="w-fit font-mono text-[10px] leading-tight text-bone/90 drop-shadow-[0_0_6px_rgba(255,204,0,0.15)] sm:text-xs"
        aria-hidden="true">{diagram}</pre>
    </div>
    <p class="border-t border-royal/40 px-4 py-2.5 font-mono text-[11px] text-toxic sm:px-6">
      <span class="text-dim">#</span> {t('homelab.note')}
    </p>
  </div>

  {/* serviços por categoria */}
  <div class="mt-6 flex items-center gap-3 font-mono text-xs">
    <span class="text-volt">// {t('homelab.services')}</span>
    <span class="h-px flex-1 bg-royal/40"></span>
  </div>
  <div class="mt-4 grid gap-x-6 gap-y-3 font-mono text-xs sm:grid-cols-2 lg:grid-cols-4">
    {
      homelabServices.map((cat) => (
        <div>
          <div class="mb-1 font-semibold text-volt">{cat.group}</div>
          <div class="text-ash">{cat.items.join(' · ')}</div>
        </div>
      ))
    }
  </div>
</section>
