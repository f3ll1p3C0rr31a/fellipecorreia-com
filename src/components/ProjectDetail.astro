---
import StatusBadge from './StatusBadge.astro';
import GlitchText from './fx/GlitchText.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const d = project.detail!;
const home = localizePath(lang, '/');
---

<article class="mx-auto max-w-3xl px-4 pb-20 pt-24 sm:px-6">
  {/* voltar */}
  <a href={`${home}#projetos`} class="font-mono text-xs text-ash transition-colors hover:text-acid">
    ← {t('case.back')}
  </a>

  {/* cabeçalho */}
  <header class="mt-6 border-b border-royal/40 pb-8">
    <div class="flex items-center gap-4">
      <span class="font-mono text-xs tracking-widest text-dim">{project.asciiTag}</span>
      <StatusBadge status={project.status} />
    </div>
    <h1 class="mt-3 font-display text-4xl font-extrabold uppercase tracking-tight sm:text-5xl">
      <GlitchText text={project.title} />
    </h1>
    <p class="mt-4 font-mono text-sm leading-relaxed text-ash">{project.tagline[lang]}</p>

    {/* links */}
    <div class="mt-6 flex flex-wrap gap-4 font-mono text-xs">
      {
        project.demo && (
          <a href={project.demo} target="_blank" rel="noopener" class="text-toxic hover:text-acid">
            [{t('cta.demo')}] ↗
          </a>
        )
      }
      {
        project.sourcePublic && project.github ? (
          <a href={project.github} target="_blank" rel="noopener" class="text-ash hover:text-acid">
            [{t('cta.source')}] ↗
          </a>
        ) : (
          <span class="text-dim">[{t('cta.source')}] ⊘ {t('projects.source.private')}</span>
        )
      }
    </div>
  </header>

  {/* corpo do case */}
  <div class="mt-10 space-y-10">
    {
      (
        [
          ['case.overview', d.overview[lang]],
          ['case.problem', d.problem[lang]],
          ['case.solution', d.solution[lang]],
        ] as const
      ).map(([key, text]) => (
        <section>
          <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-acid">{`> ${t(key)}`}</h2>
          <p class="font-mono text-sm leading-relaxed text-bone/90">{text}</p>
        </section>
      ))
    }

    {/* destaques */}
    <section>
      <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-acid">{`> ${t('case.features')}`}</h2>
      <ul class="space-y-1.5">
        {
          d.features[lang].map((f) => (
            <li class="flex gap-2 font-mono text-sm text-bone/90">
              <span class="text-toxic">[✓]</span>
              {f}
            </li>
          ))
        }
      </ul>
    </section>

    {/* resultado */}
    <section class="border-l-2 border-volt pl-4">
      <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-volt">{`> ${t('case.result')}`}</h2>
      <p class="font-mono text-sm leading-relaxed text-bone">{d.result[lang]}</p>
    </section>

    {/* stack */}
    <section>
      <h2 class="mb-3 font-mono text-xs uppercase tracking-widest text-ash">{`> ${t('case.stack')}`}</h2>
      <ul class="flex flex-wrap gap-2">
        {
          project.stack.map((s) => (
            <li class="border border-royal/50 px-2 py-1 font-mono text-xs text-ash">{s}</li>
          ))
        }
      </ul>
    </section>
  </div>
</article>
