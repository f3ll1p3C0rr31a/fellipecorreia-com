---
import SectionHeader from './SectionHeader.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { site } from '../data/site';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const facts = [
  { k: 'role', v: 'Full-Stack · DevOps' },
  { k: 'based', v: site.location[lang] },
  { k: 'focus', v: 'Infra · CI/CD · IA local' },
  { k: 'stack', v: 'Docker · Linux · Next.js' },
  { k: 'langs', v: 'PT · EN · ES' },
];
---

<section id="sobre" class="mx-auto max-w-6xl scroll-mt-16 px-4 py-16 sm:px-6">
  <SectionHeader index={1} id="sobre" cmd="cat sobre.md" title={lang === 'pt' ? 'sobre' : 'about'} accent="acid" />

  <div class="grid gap-10 lg:grid-cols-[1.7fr_1fr]">
    {/* narrativa */}
    <div>
      <p class="mb-6 border-l-2 border-acid pl-4 font-display text-lg font-semibold leading-snug text-bone sm:text-xl">
        {t('about.kicker')}
      </p>
      <div class="space-y-4 font-mono text-sm leading-relaxed text-ash sm:text-[15px]">
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>
      </div>
    </div>

    {/* card whoami */}
    <aside class="h-fit border border-royal/60 bg-royal/10 font-mono text-xs">
      <div class="flex items-center gap-1.5 border-b border-royal/60 bg-royal/20 px-3 py-2">
        <span class="size-2 rounded-full bg-acid"></span>
        <span class="size-2 rounded-full bg-volt"></span>
        <span class="size-2 rounded-full bg-ash/40"></span>
        <span class="ml-2 text-ash">whoami</span>
      </div>
      <dl class="space-y-2 p-4">
        {
          facts.map((f) => (
            <div class="flex gap-3">
              <dt class="w-14 shrink-0 text-acid">{f.k}</dt>
              <dd class="text-bone">{f.v}</dd>
            </div>
          ))
        }
        <div class="mt-3 flex gap-3 border-t border-royal/40 pt-3">
          <dt class="w-14 shrink-0 text-acid">status</dt>
          <dd class="flex items-center gap-1.5 text-bone">
            <span class="inline-block size-1.5 animate-pulse rounded-full bg-volt"></span>
            {t('about.status.value')}
          </dd>
        </div>
      </dl>
    </aside>
  </div>
</section>
