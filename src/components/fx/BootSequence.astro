---
/**
 * Tela "clique para iniciar" → boot POST/NFO → transição CRT pro hero.
 * O clique/tecla que inicia libera o áudio (política de autoplay), então
 * o som toca durante toda a intro. Roda 1x por sessão; reduced-motion
 * pula tudo.
 */
interface Props {
  skipLabel: string;
  gateLabel: string;
  lines: string[];
}
const { skipLabel, gateLabel, lines } = Astro.props;
---

<boot-sequence
  class="fixed inset-0 z-100 hidden flex-col bg-void font-mono text-sm leading-relaxed text-bone sm:text-base"
  data-lines={JSON.stringify(lines)}
>
  {/* tela de entrada */}
  <div
    data-gate
    class="flex flex-1 cursor-pointer flex-col items-center justify-center gap-6 p-6 text-center"
  >
    <span class="font-pixel text-[10px] tracking-widest text-dim">FBC-SYSTEM // standby</span>
    <span class="animate-blink text-lg text-acid sm:text-xl">[ {gateLabel} ]</span>
    <span class="text-xs text-dim">▸ fellipecorreia.com</span>
  </div>

  {/* console do boot */}
  <div data-console class="hidden flex-1 flex-col justify-between p-6 sm:p-10">
    <pre class="whitespace-pre-wrap" data-screen></pre>
    <p class="text-xs text-ash">{skipLabel}</p>
  </div>
</boot-sequence>

<script>
  class BootSequence extends HTMLElement {
    connectedCallback() {
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced || sessionStorage.getItem('fbc-booted')) {
        this.remove();
        return;
      }

      this.classList.remove('hidden');
      this.classList.add('flex');
      document.documentElement.style.overflow = 'hidden';

      const gate = this.querySelector<HTMLElement>('[data-gate]')!;
      const consoleEl = this.querySelector<HTMLElement>('[data-console]')!;
      const screen = this.querySelector<HTMLPreElement>('[data-screen]')!;
      const lines: string[] = JSON.parse(this.dataset.lines ?? '[]');

      const begin = (e?: Event) => {
        e?.stopPropagation();
        gate.removeEventListener('click', begin);
        removeEventListener('keydown', begin);
        gate.classList.add('hidden');
        consoleEl.classList.remove('hidden');
        consoleEl.classList.add('flex');
        this.#runBoot(screen, lines);
      };
      // o mesmo gesto libera o áudio (AudioAmbient escuta o pointerdown)
      gate.addEventListener('click', begin);
      addEventListener('keydown', begin);
    }

    #runBoot(screen: HTMLPreElement, lines: string[]) {
      let line = 0;
      let char = 0;
      let out = '';
      let timer = 0;
      const CURSOR = '█';

      const finish = () => {
        clearTimeout(timer);
        sessionStorage.setItem('fbc-booted', '1');
        removeEventListener('keydown', finish);
        this.removeEventListener('click', finish);

        const done = () => {
          document.documentElement.style.overflow = '';
          this.remove();
        };
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
          done();
          return;
        }
        // desligamento estilo CRT + blip de power-off
        window.dispatchEvent(new CustomEvent('fbc:crt-off'));
        this.classList.add('crt-off');
        setTimeout(done, 720);
      };

      const tick = () => {
        if (line >= lines.length) {
          screen.textContent = out + CURSOR;
          timer = window.setTimeout(finish, 520);
          return;
        }
        const current = lines[line];
        const typing = line === lines.length - 1;
        if (char < current.length) {
          if (typing) {
            out += current[char];
            char++;
          } else {
            out += current;
            char = current.length;
          }
        }
        if (char >= current.length) {
          out += '\n';
          line++;
          char = 0;
        }
        screen.textContent = out + CURSOR;
        const delay = char === 0 ? 90 + Math.random() * 160 : 24 + Math.random() * 40;
        timer = window.setTimeout(tick, delay);
      };

      tick();
      // pular durante a digitação
      setTimeout(() => {
        addEventListener('keydown', finish);
        this.addEventListener('click', finish);
      }, 60);
    }
  }
  customElements.define('boot-sequence', BootSequence);
</script>
